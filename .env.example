# Copy to .env for local runs:  cp .env.example .env   then edit.
# (.env is git-ignored so your topic stays private.)

# Your private ntfy topic (subscribe to this in the ntfy phone app).
# Pick something hard to guess - anyone who knows the topic can read/post to it.
NTFY_TOPIC=replace-with-your-private-topic

# Optional overrides -------------------------------------------------
# NTFY_SERVER=https://ntfy.sh
# STOREFRONTS=us,ca
# STAGES=R32,R16,QTR,SMF,BRZ,FNL
# US_COUNTRIES=US          # US site: which host countries to watch (US venues)
# CA_VENUE_CODES=NN_VAN    # CA site: BC Place Vancouver only (NN_TOR = Toronto)
# REALERT_HOURS=6
